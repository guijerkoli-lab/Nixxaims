local function IsOnAlliedTeam(player)
    if not MenuConfig.TeamCheckEnabled then return false end
    if LocalPlayer.Team and player.Team then return LocalPlayer.Team == player.Team end
    if LocalPlayer.TeamColor and player.TeamColor then return LocalPlayer.TeamColor == player.TeamColor end
    return false
end

-- Mecânica Raycast para conferência de parede (Wall Check)
local function IsPlayerVisible(targetPart)
    if not MenuConfig.WallCheckEnabled then return true end
    
    local character = LocalPlayer.Character
    if not character then return false end
    
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {character, Camera, ScreenGui}
    params.IgnoreWater = true
    
    local result = workspace:Raycast(origin, direction, params)
    
    -- Se o raycast não atingir nada antes do alvo ou atingir o próprio personagem do alvo, está livre.
    if not result or result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

-- AIMLOCK ENGINE - FILTRAGEM DINÂMICA POR PROXIMIDADE DO INIMIGO
local function GetAimTarget()
    local targetPart = nil
    local shortestMagnitude = math.huge
    local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local localCharacter = LocalPlayer.Character
    local localHrp = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")

    if not localHrp then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            if IsOnAlliedTeam(p) then continue end
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            local head = p.Character:FindFirstChild("Head")
            local enemyHrp = p.Character:FindFirstChild("HumanoidRootPart")
            
            if hum and hum.Health > 0 and head and enemyHrp then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local fovDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if fovDist < MenuConfig.FovRadius then
                        -- Adiciona verificação de Visibilidade (Wall Check)
                        if IsPlayerVisible(head) then
                            local realDistance = (localHrp.Position - enemyHrp.Position).Magnitude
                            if realDistance < shortestMagnitude then
                                shortestMagnitude = realDistance
                                targetPart = head
                            end
                        end
                    end
                end
            end
        end
    end
    return targetPart
end

-- LOOP PRINCIPAL (AIMLOCK + FOV)
RunService.RenderStepped:Connect(function()
    if MenuConfig.AimlockEnabled and IsAiming then
        local target = GetAimTarget()
        if target then
            local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
            Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, MenuConfig.AimSmoothness)
        end
    end

    if MenuConfig.FovScreenEnabled and Camera.FieldOfView ~= 80 then
        Camera.FieldOfView = 80
    end
end)

-- ESP ENGINE TRADICIONAL
local function ApplyCleanESP(player)
    local Line = Instance.new("Frame", ScreenGui); Line.BorderSizePixel = 0; Line.Visible = false
    local Box = Instance.new("Frame", ScreenGui); Box.BackgroundTransparency = 1; Box.Visible = false
    local Stroke = Instance.new("UIStroke", Box); Stroke.Thickness = 1.5
    
    local Text = Instance.new("TextLabel", ScreenGui); Text.BackgroundTransparency = 1; Text.Font = Enum.Font.SourceSansBold; Text.Visible = false
    local Health = Instance.new("Frame", ScreenGui); Health.BorderSizePixel = 0; Health.Visible = false
    local HealthLabel = Instance.new("TextLabel", ScreenGui); HealthLabel.BackgroundTransparency = 1; HealthLabel.Font = Enum.Font.SourceSansBold; HealthLabel.TextColor3 = Color3.fromRGB(255, 255, 255); HealthLabel.Visible = false

    RunService.RenderStepped:Connect(function()
        if not player or not player.Parent or not MenuConfig.EspEnabled or IsOnAlliedTeam(player) then
            Line.Visible = false; Box.Visible = false; Text.Visible = false; Health.Visible = false; HealthLabel.Visible = false
            return
        end

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local head = char and char:FindFirstChild("Head")

        if hrp and hum and hum.Health > 0 and head then
            local hrpPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local distance = (Camera.CFrame.Position - hrp.Position).Magnitude

            if onScreen and distance <= MenuConfig.EspMaxDistance then
                local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.5, 0))
                local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                
                local boxHeight = math.abs(headPos.Y - legPos.Y)
                local boxWidth = boxHeight / 1.5

                Stroke.Color = MenuConfig.EspColor

                if MenuConfig.EspBox then
                    Box.Size = UDim2.new(0, boxWidth, 0, boxHeight)
                    Box.Position = UDim2.new(0, hrpPos.X - boxWidth / 2, 0, headPos.Y)
                    Box.Visible = true
                else Box.Visible = false end

                if MenuConfig.EspNames then
                    Text.Text = player.Name
                    Text.TextSize = MenuConfig.EspFontScale
                    Text.TextColor3 = Color3.fromRGB(255, 255, 255)
                    Text.Position = UDim2.new(0, hrpPos.X - 100, 0, headPos.Y - 16)
                    Text.Size = UDim2.new(0, 200, 0, 14)
                    Text.Visible = true
                else Text.Visible = false end

                local hpPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)

                if MenuConfig.EspHealth then
                    Health.Size = UDim2.new(0, 3, 0, boxHeight * hpPct)
                    Health.Position = UDim2.new(0, hrpPos.X - (boxWidth / 2) - 6, 0, headPos.Y + (boxHeight * (1 - hpPct)))
                    Health.BackgroundColor3 = Color3.fromRGB(255 - (hpPct*255), hpPct*255, 0)
                    Health.Visible = true
                else Health.Visible = false end

                if MenuConfig.EspHealthPercent then
                    HealthLabel.Text = math.floor(hpPct * 100) .. "%"
                    HealthLabel.TextSize = MenuConfig.EspFontScale - 2
                    HealthLabel.Position = UDim2.new(0, hrpPos.X - (boxWidth / 2) - 34, 0, headPos.Y + (boxHeight * (1 - hpPct)) - 4)
                    HealthLabel.Size = UDim2.new(0, 24, 0, 12)
                    HealthLabel.Visible = true
                else HealthLabel.Visible = false end

                if MenuConfig.EspLines then
                    local startPoint = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    local endPoint = Vector2.new(hrpPos.X, hrpPos.Y)
                    local vector = endPoint - startPoint
                    Line.Size = UDim2.new(0, 1.5, 0, vector.Magnitude)
                    Line.Position = UDim2.new(0, startPoint.X, 0, startPoint.Y)
                    Line.Rotation = -math.deg(math.atan2(vector.X, vector.Y))
                    Line.AnchorPoint = Vector2.new(0.5, 0)
                    Line.BackgroundColor3 = MenuConfig.EspColor
                    Line.Visible = true
                else Line.Visible = false end
                return
            end
        end
        Line.Visible = false; Box.Visible = false; Text.Visible = false; Health.Visible = false; HealthLabel.Visible = false
    end)
end

for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then ApplyCleanESP(p) end end
