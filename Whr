-- Sistema de Arrastar com Bloqueio de Posição
local dragging, dragInput, dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    AimlockButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

AimlockButton.InputChanged:Connect(function(input)
    if not MenuConfig.FixButtonLock then
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then 
            dragInput = input 
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateDrag(input)
    end
end)

AimlockButton.TouchLongPress:Connect(function(touchPositions, state)
    if not MenuConfig.FixButtonLock then
        if state == Enum.UserInputState.Begin then 
            dragging = true 
            dragStart = Vector3.new(touchPositions[1].X, touchPositions[1].Y, 0) 
            startPos = AimlockButton.Position
        elseif state == Enum.UserInputState.End or state == Enum.UserInputState.Cancel then 
            dragging = false 
        end
    end
end)

AimlockButton.MouseButton2Down:Connect(function()
    if not MenuConfig.FixButtonLock then
        dragging = true
        local mousePos = UserInputService:GetMouseLocation()
        dragStart = Vector3.new(mousePos.X, mousePos.Y, 0)
        startPos = AimlockButton.Position
    end
end)

UserInputService.InputEnded:Connect(function(input)
