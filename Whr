    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Text = "   " .. text
    btn.ZIndex = 6
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    Instance.new("UIStroke", btn).Color = Color3.fromRGB(22, 22, 22)

    local ind = Instance.new("Frame")
    ind.Size = UDim2.new(0, 36, 0, 18)
    ind.Position = UDim2.new(1, -44, 0.5, -9)
    ind.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    ind.ZIndex = 6
    ind.Parent = btn
    Instance.new("UICorner", ind).CornerRadius = UDim.new(0, 9)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 12, 0, 12)
    dot.Position = UDim2.new(0, 3, 0.5, -6)
    dot.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    dot.ZIndex = 7
    dot.Parent = ind
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local state = initialValue
    local function update()
        dot.Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
        dot.BackgroundColor3 = state and Color3.fromRGB(0, 180, 255) or Color3.fromRGB(100, 100, 100)
    end
    btn.MouseButton1Click:Connect(function() state = not state update() if callback then callback(state) end end)
    update()
end

local function addSlider(parent, title, min, max, initialValue, formatStr, callback)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, -6, 0, 45)
    container.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    container.ZIndex = 6
    container.Parent = parent
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 4)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -20, 0, 20)
    lbl.Position = UDim2.new(0, 10, 0, 2)
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.Font = Enum.Font.SourceSans
    lbl.TextSize = 12
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 6
    lbl.Parent = container

    local slideTrack = Instance.new("Frame")
    slideTrack.Size = UDim2.new(1, -20, 0, 4)
    slideTrack.Position = UDim2.new(0, 10, 0, 30)
    slideTrack.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    slideTrack.ZIndex = 6
    slideTrack.Parent = container
    Instance.new("UICorner", slideTrack).CornerRadius = UDim.new(1, 0)

    local slideFill = Instance.new("Frame")
    slideFill.Size = UDim2.new(0, 0, 1, 0)
    slideFill.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
    slideFill.BorderSizePixel = 0
    slideFill.ZIndex = 7
    slideFill.Parent = slideTrack

    local slideBtn = Instance.new("TextButton")
    slideBtn.Size = UDim2.new(0, 12, 0, 12)
    slideBtn.AnchorPoint = Vector2.new(0.5, 0.5)
    slideBtn.Position = UDim2.new(0, 0, 0.5, 0)
    slideBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    slideBtn.Text = ""
    slideBtn.ZIndex = 8
    slideBtn.Parent = slideTrack
    Instance.new("UICorner", slideBtn).CornerRadius = UDim.new(1, 0)

    local currentValue = initialValue
    local function renderValue(val)
        lbl.Text = title .. ": " .. string.format(formatStr, val)
        local pct = (val - min) / (max - min)
        slideBtn.Position = UDim2.new(pct, 0, 0.5, 0)
        slideFill.Size = UDim2.new(pct, 0, 1, 0)
    end

    local function updateFromPos(inputX)
        local absPos = slideTrack.AbsolutePosition.X
        local absSize = slideTrack.AbsoluteSize.X
        local pct = math.clamp((inputX - absPos) / absSize, 0, 1)
        currentValue = min + (pct * (max - min))
        renderValue(currentValue)
        if callback then callback(currentValue) end
    end

    local dragging = false
    slideBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then updateFromPos(input.Position.X) end end)

    renderValue(currentValue)
end

