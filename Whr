local function addToggle(parent, text, initialValue, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -6, 0, 32)
    btn.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 13
